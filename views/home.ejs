<!DOCTYPE html>
<html>
<head>
    <title>URL Shortener - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">URL Shortener</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/auth/signout">Sign Out</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <% if (typeof error !== 'undefined') { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <div class="card">
                    <div class="card-header">
                        <h3>Shorten a URL</h3>
                    </div>
                    <div class="card-body">
                        <form action="/url" method="POST">
                            <div class="mb-3">
                                <input type="url" class="form-control" name="url" placeholder="Enter URL to shorten" required>
                            </div>
                            <button type="submit" class="btn btn-primary">Shorten</button>
                        </form>
                    </div>
                </div>

                <% if (typeof id !== 'undefined') { %>
                    <div class="alert alert-success mt-3">
                        Your shortened URL: <a href="/url/<%= id %>" target="_blank"><%= id %></a>
                    </div>
                <% } %>

                <div class="card mt-4">
                    <div class="card-header">
                        <h3>Your URLs</h3>
                    </div>
                    <div class="card-body">
                        <% if (typeof urls !== 'undefined' && urls.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Short URL</th>
                                            <th>Original URL</th>
                                            <th>Clicks</th>
                                            <th>Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% urls.forEach(url => { %>
                                            <tr>
                                                <td><a href="/url/<%= url.shortID %>" target="_blank"><%= url.shortID %></a></td>
                                                <td><%= url.redirectedURL %></td>
                                                <td><%= url.totalClicks %></td>
                                                <td><%= new Date(url.createdAt).toLocaleDateString() %></td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-center">No URLs shortened yet.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>